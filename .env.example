# ═══════════════════════════════════════════════════════
# AutoDev Agent — Environment Variables
# ═══════════════════════════════════════════════════════

# ── Required ──────────────────────────────────────────

# OpenRouter API key (get one at https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-xxxx

# GitHub personal access token (scope: repo)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxx

# ── Optional: Notifications ───────────────────────────

# Webhook URL for notifications (Slack, Discord, or custom)
NOTIFY_WEBHOOK_URL=https://hooks.slack.com/services/xxx

# Shared secret for webhook authentication
AUTODEV_SECRET=your-secret-here

# ── Optional: Additional APIs ─────────────────────────

# OpenAI API key (fallback if OpenRouter fails)
OPENAI_API_KEY=

# TinyFish API key (web search for content module)
TINYFISH_API_KEY=

# ── Agent Configuration ───────────────────────────────

# Run immediately on startup
AUTODEV_RUN_NOW=false

# Dry run mode (analyze without pushing)
AUTODEV_DRY_RUN=true

# Cron schedule (default: every 4 hours)
AUTODEV_SCHEDULE=0 */4 * * *

# ── Quick Start (single project, no config file) ─────

# AUTODEV_REPO_URL=https://github.com/user/repo.git
# AUTODEV_PROJECT_NAME=my-project
# AUTODEV_BRANCH=main
# AUTODEV_BUILD_CMD=npm run build
# AUTODEV_MODULES=security,performance,seo,quality
